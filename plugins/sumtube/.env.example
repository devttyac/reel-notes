# Copy this file to .env and fill in your keys.
# .env is gitignored at the repo root.
#
# Why SUMTUBE_API_KEY exists:
# Claude Code's sandbox injects an empty ANTHROPIC_API_KEY into all child
# processes, overwriting any shell-level value. SUMTUBE_API_KEY bypasses this.
# When running the script outside Claude Code, ANTHROPIC_API_KEY also works.

SUMTUBE_API_KEY=sk-ant-your-anthropic-api-key-here

# Optional — enables Whisper transcription fallback for caption-less videos.
GROQ_API_KEY=gsk_your-groq-api-key-here
